
// ========================== PRACTICE BINDS ============================
//                   This is separate config for practice

// Map executing for instant smokes practice
alias "map_selection" "nums_to_maplist; say Choose any map (open console).; echoing"
bind "KEY" "map_selection"

alias "echoing" "echo; echo	======================== CHOOSE THE MAP ========================; echo Press 1 to choose Ancient; echo Press 2 to choose Anubis; echo Press 3 to choose Dust II; echo Press 4 to choose Inferno; echo Press 5 to choose Mirage; echo Press 6 to choose Nuke; Press 7 to choose Vertigo echo" 
alias "nums_to_maplist" "bind 1 choose_ancient; bind 2 choose_anubis; bind 3 choose_dust2; bind 4 choose_inferno; bind 5 choose_mirage; bind 6 choose_nuke; bind 7 choose_vertigo"
alias "nums_to_default" "primary_weapon; secondary_weapon; secondary_weapon; knife; zeus; bomb; unbind 7"
 
alias "choose_ancient" "exec other_cfgs/map_ancient_team_queue"
alias "choose_anubis" "exec other_cfgs/map_anubis_team_queue"
alias "choose_dust2" "exec other_cfgs/map_dust2_team_queue"
alias "choose_inferno" "exec other_cfgs/map_inferno_team_queue"
alias "choose_mirage" "exec other_cfgs/map_mirage_team_queue"
alias "choose_nuke" "exec other_cfgs/map_nuke_team_queue"
alias "choose_vertigo" "exec other_cfgs/map_vertigo_team_queue"

alias "primary_weapon" "exec other_cfgs/slot1_primary_weapon"
alias "secondary_weapon" "exec other_cfgs/slot2_secondary_weapon"
alias "knife" "exec other_cfgs/slot3_knife"
alias "zeus" "exec other_cfgs/slot11_zeus"
alias "bomb" "exec other_cfgs/slot5_bomb"
alias "he_grenade" "exec other_cfgs/slot6_he_grenade"
alias "flashbang" "exec other_cfgs/slot7_flashbang"
alias "smoke" "exec other_cfgs/slot8_smoke"
alias "decoy" "exec other_cfgs/slot9_decoy"
alias "molotov" "exec other_cfgs/slot10_molotov"


// Bots
bind "-" "bot_add ct"                                                      //Add CT bot
bind "=" "bot_add_t"                                                       //Add T bot
bind "BACKSPACE" "bot_kick"                                                //Kick bots
bind "KEY" "bot_place"                                                     //Place bot
bind "KEY" "toggle bot_crouch true false; say .botduck"                    //Made a bot crouch (refrag.gg: add crouched bot)


// Nades
alias "all_keys_to_default" "bind SCANCODE44 +duck-jump; bind SCANCODE8 +use; bind SCANCODE21 rethrow; bind SCANCODE23 +spray_menu; bind SCANCODE5 +buymenu"
alias "exept_jt_key" "bind SCANCODE23 +spray_menu; bind SCANCODE8 +use; bind SCANCODE21 rethrow; bind SCANCODE5 +buymenu; alias keys_to_default all_keys_to_default"
alias "exept_ft_key" "bind SCANCODE44 +duck-jump; bind SCANCODE8 +use; bind SCANCODE21 rethrow; bind SCANCODE5 +buymenu; alias keys_to_default all_keys_to_default"
alias "exept_fjt_key" "bind SCANCODE44 +duck-jump; bind SCANCODE21 rethrow; bind SCANCODE23 +spray_menu; bind SCANCODE5 +buymenu; alias keys_to_default all_keys_to_default"
alias "-backward-jump-throw_t" "reset_t_2; -back; bind SCANCODE21 rethrow"

alias "rethrow" "sv_rethrow_last_grenade; say .rethrow"
bind "R" "rethrow"                                                         //Rethrow last grenade

bind "KEY" "ent_fire smokegrenade_projectile kill; stopsound; say .clear"  //Erase smoke
bind "KEY" "+jump"                                                         //Jump for jump-throw prediction


// Increase time speed  (1st method)
alias "+timespeedup" "host_timescale 20"
alias "-timespeedup" "host_timescale 1"
bind "KEY" "+timespeedup"

// Increase time speed  (2st method, less lags)
alias "+timespeedup2" "host_framerate 20"
alias "-timespeedup2" "host_framerate 1"
bind "KEY" "+timespeedup2"


// Noclip
alias "+noclip" "noclip"
alias "-noclip" "noclip"
bind "KEY" "+noclip"
bind "KEY" "noclip"


// Toggle regeneration false/true
alias "regen" "regen_off"
alias "regen_off" "sv_regeneration_force_on false; alias regen regen_on; say .regenoff"
alias "regen_on" "sv_regeneration_force_on true; alias regen regen_off; say .regenon"
bind "KEY" "regen"


// Disable HUD (for video recording)
bind "KEY" "toggle cl_draw_only_deathnotices 0 1"


// Change viewmodel
alias "viewmodel_preset" "desktop"
alias "desktop" "say desktop viewmodel; viewmodel_presetpos 1; alias viewmodel_preset couch"
alias "couch" "say couch viewmodel; viewmodel_presetpos 2; alias viewmodel_preset classic"
alias "classic" "say classic viewmodel; viewmodel_presetpos 3; alias viewmodel_preset desktop"
bind "KEY" "viewmodel_preset"


// Spawn test (example for Ancient)
alias "spawn_test" "team_ct; team_t"
alias "team_ct" "setpos_player 1 -192.000000 1696.000000 26.053043"
alias "team_t" "setpos_player 4 -520.000000 -2224.000000 -163.255737"
bind "KEY" "mp_freezetime 3; mp_warmup_start; mp_warmup_end; mp_roundtime_defuse 60; sv_hide_roundtime_until_seconds 0; spawn_test"

bind "KEY" "mp_warmup_start"
bind "KEY" "mp_warmup_start; mp_warmup_end"



say "Practice binds have been executed."
